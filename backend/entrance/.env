# 检索层配置
RETRIEVAL_URL=http://172.25.178.29:18020/query
HTTP_TIMEOUT=60000

# NLU 配置（可选）
ENABLE_NLU=false
NLU_PIPELINE_URL=http://localhost:3004/api/nlu/process

# NLU 模型路径配置（本地模式）
REXUNINLU_MODEL_PATH=
SLIMPLM_MODEL_PATH=
TURNSENSE_MODEL_PATH=

# 或者使用 API 模式（如果模型部署为 HTTP 服务）
REXUNINLU_API_URL=
SLIMPLM_API_URL=
TURNSENSE_API_URL=

# CPU 优化配置（无 GPU 时启用）
NLU_CPU_OPTIMIZATION=true
NLU_4BIT_QUANTIZATION=true

# Context Memory 配置（可选）
ENABLE_CONTEXT_MEMORY=true
CONTEXT_MEMORY_URL=http://localhost:3006

# 问题过滤配置
ENABLE_QUESTION_FILTER=true
QUESTION_FILTER_URL=http://localhost:3005

# 问题分类配置
ENABLE_QUESTION_CLASSIFICATION=true
FIRSTLAYER_URL=http://localhost:3004
