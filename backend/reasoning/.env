# ============================================================
# 推理与引用层 (Reasoning Layer) 环境变量配置
# 文件：backend/reasoning/.env
#
# 说明：
#   - 此文件包含 LLM API 等敏感信息，请勿提交到 Git
#   - 环境变量优先级高于内置默认值，低于 --provider 命令行参数
#   - 若不需要覆盖内置配置，可将下方变量留空或注释掉
# ============================================================

# ──────────────────────────────────────────────
# 当前激活的 LLM 供应商
# 可选值：glm5 | kimi | minimax | qwen | openai
# ──────────────────────────────────────────────
LLM_ACTIVE_PROVIDER=glm5

# ──────────────────────────────────────────────
# 全局推理参数默认值（所有模型共享，可被 provider 内覆盖）
# ──────────────────────────────────────────────
LLM_DEFAULT_TEMPERATURE=0.1
LLM_DEFAULT_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# 智谱 GLM-5
# ──────────────────────────────────────────────
LLM_GLM5_API_KEY=your-moonshot-api-key-here
LLM_GLM5_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_GLM5_MODEL=glm-5v-turbo
LLM_GLM5_TEMPERATURE=0.1
LLM_GLM5_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# Kimi (Moonshot AI)
# ──────────────────────────────────────────────
LLM_KIMI_API_KEY=your-moonshot-api-key-here
LLM_KIMI_BASE_URL=https://api.moonshot.cn/v1
LLM_KIMI_MODEL=moonshot-v1-8k
LLM_KIMI_TEMPERATURE=0.1
LLM_KIMI_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# MiniMax
# ──────────────────────────────────────────────
LLM_MINIMAX_API_KEY=your-minimax-api-key-here
LLM_MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_MINIMAX_MODEL=MiniMax-Text-01
LLM_MINIMAX_TEMPERATURE=0.1
LLM_MINIMAX_MAX_TOKENS=2000
LLM_MINIMAX_EXTRA_BODY={}

# ──────────────────────────────────────────────
# 通义千问 (Qwen)
# ──────────────────────────────────────────────
LLM_QWEN_API_KEY=your-dashscope-api-key-here
LLM_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_QWEN_MODEL=qwen-turbo
LLM_QWEN_TEMPERATURE=0.1
LLM_QWEN_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# OpenAI（备用）
# ──────────────────────────────────────────────
LLM_OPENAI_API_KEY=your-openai-api-key-here
LLM_OPENAI_BASE_URL=
LLM_OPENAI_MODEL=gpt-4-turbo
LLM_OPENAI_TEMPERATURE=0.1
LLM_OPENAI_MAX_TOKENS=2000
