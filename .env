# ==================== 文件存储配置 ====================
# 上传文件存储目录（默认：./storage/raw）
UPLOAD_DIR=../storage/raw

# ==================== 服务器配置 ====================
NODE_ENV=production
PORT=3002
HOST=0.0.0.0

# ==================== LLM API 配置（可选） ====================
# 如果配置了 LLM API，将启用语义检索（向量）
# 否则使用关键词检索（兜底模式）

# OpenAI API
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# 嵌入模型配置
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=1536

# ==================== 系统配置 ====================
# 严格模式：必须根据文档回答，不能编造
STRICT_MODE=true

# ==================== 前端配置 ====================
# 注意：前端使用 frontend/.env.local 中的配置
# 无论是否使用 Nginx，都使用相对路径 /api
# NEXT_PUBLIC_API_URL=/api (在 frontend/.env.local 中配置)

# ==================== FirstLayer 问题分类服务配置 ====================
# FirstLayer 服务地址
FIRSTLAYER_URL=http://localhost:3004

# 启用问题分类功能
ENABLE_QUESTION_CLASSIFICATION=true

# 分类请求超时时间（毫秒）
CLASSIFY_TIMEOUT=5000
