{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Reasoning: main",
            "type": "debugpy",
            "request": "launch",
            "module": "reasoning.main",
            "cwd": "${workspaceFolder}/src/backend",
            "console": "integratedTerminal",
            "args": ["--port", "8001"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/backend"
            }
        },
        {
            "name": "Retrieval: retrieval.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/backend/retrieval/retrieval.py",
            "cwd": "${workspaceFolder}/src/backend",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/backend"
            }
        }
    ]
}
