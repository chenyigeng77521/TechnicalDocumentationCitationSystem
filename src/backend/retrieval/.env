# =============================================================================
# Retrieval 模块环境变量配置
# 放置于 src/backend/retrieval/.env，由 retrieval.py 显式加载
# =============================================================================

# -------------------- 向量库 API 配置 --------------------
VECTOR_API_URL=http://localhost:3003
# VECTOR_API_KEY=                      # 可选，向量库 API 密钥

# -------------------- Score 阈值过滤 --------------------
VECTOR_SCORE_THRESHOLD=0.55
BM25_SCORE_THRESHOLD=-999.0
# RETRIEVAL_SCORE_THRESHOLD=0.0        # 兼容旧配置名（已废弃，仅作用于向量检索）

# -------------------- Embedding 维度 --------------------
EMBEDDING_DIMENSION=1024

# -------------------- 查询扩展配置 --------------------
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_MODEL=aliyun/deepseek-v3.2
QUERY_EXPANSION_NUM=3

# 查询扩展用 LLM API（启用查询扩展时必需）
OPENAI_API_KEY=sk-
OPENAI_API_BASE=https://aigw.asiainfo.com/v1

# -------------------- 重排序配置 --------------------
RERANK_TOP_N=5
RERANK_CONTEXT_WINDOW=1

# 外部重排序 API（置空则回退本地 CrossEncoder）
RERANK_API_URL=https://aigw.asiainfo.com/v1/rerank
RERANK_API_KEY=sk-
RERANK_API_MODEL=10086/bge-reranker-v2-m3

# -------------------- 外部 Embedding API --------------------
# 置空则回退本地 HuggingFaceEmbeddings
EMBEDDING_API_URL=https://aigw.asiainfo.com/v1/embeddings
EMBEDDING_API_KEY=sk-
EMBEDDING_API_MODEL=10086/bge-m3

# -------------------- API 超时配置（秒）--------------------
SEARCH_TIMEOUT=30
HEALTH_TIMEOUT=5

# -------------------- 自适应 TopK 边界 --------------------
ADAPTIVE_TOPK_MIN=5
ADAPTIVE_TOPK_MAX=25

# =============================================================================
# 使用说明：
# 1. 如需本地模型模式，将 EMBEDDING_API_URL 和 RERANK_API_URL 置空即可
# 2. API Key 当前为占位符（sk-），请替换为真实密钥
# 3. 修改后无需重启服务， retrieval.py 在模块导入时读取一次
# =============================================================================
