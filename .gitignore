.idea/

# Python 缓存文件
__pycache__/
*.pyc
*.pyo

# 评测运行产物（动态生成，不提交）
eval/report.md
eval/report-*.md


# 个人本地归档（不提交）
backend/back/

# 用户上传的原始文件 / 系统生成的索引数据（不提交，每个开发者本地独立）
backend/storage/raw/*
backend/storage/index/*.db*
# 但保留目录结构（让 git 知道该有这俩目录）
!backend/storage/raw/.gitkeep
!backend/storage/index/.gitkeep

# Ingestion 运行时产物（log / pid 等动态生成）
backend/ingestion/logs/*
!backend/ingestion/logs/.gitkeep

# pytest / coverage
.pytest_cache/
.coverage

# 环境变量文件（含 API key 等敏感信息，绝不提交）
.env.local
src/.env.aigw
src/.env.local
src/backend/**/.env.local
backend/**/.env.local
# 但保留 .env.example / .env.aigw.example（团队共享模板）
!.env.example
!**/.env.example
!**/.env.aigw.example
# 注：src/.env 是团队共享的非敏感配置（已在 git tracked），不 ignore

# 新结构：DB 和 raw 文件（迁到 src/）
src/backend/storage/raw/*
src/backend/storage/index/*.db*
!src/backend/storage/raw/.gitkeep
!src/backend/storage/index/.gitkeep

# 新结构：ingestion logs
src/backend/ingestion/logs/*
!src/backend/ingestion/logs/.gitkeep

# 个人联调脚本（cloudflared tunnel + 本地服务重启），不提交
scripts/openTunnels.sh
scripts/restartServices.sh
# tunnel 运行时产物
src/logs/tunnel_*.log
src/logs/tunnel_*.pid
src/logs/tunnel_urls.txt

# ==================== 重构后新规范 ====================
# 索引数据库（305MB，每个开发者本地 reindex 生成，超 GitHub 单文件 100MB 限制）
src/backend/database/
# SQLite 运行时辅助文件
*.db
*.db-shm
*.db-wal

# 含 AIGW key 的本地配置（绝不提交；之前误 tracked，已 git rm --cached）
src/backend/reasoning/.env
src/backend/entrance/.env

# 上传暂存 / 批量结果（运行时生成）
src/backend/storage/batchtest/
src/backend/storage/result/

# Reasoning 运行时产物
src/backend/reasoning/.reasoning.pid
src/backend/reasoning/logs/
src/backend/reasoning/storage/

# reindex bug 残留（项目根/backend/storage 错误位置）
src/backend/ingestion/backend/

# 前端 / 依赖 / 构建产物
**/node_modules/
**/dist/
**/.next/

# Python 字节码
**/*.pyc

# 各种日志
*.log
src/logs/*.log
logs/

# 评测目录（动态生成，体积大）
eval/


# venv（Mac/Linux 受 PEP 668 限制时本地用）
.venv*/
venv/
